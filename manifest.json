{
  "manifest_version": 2,
  "name": "yt-time-cal-tracker",
  "version": "0.1",
  "description": "track time on youtube with google calendar and auto summary of what watched ",
  "permissions": [
    "storage",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "background": {
    "scripts": ["background.js", "config.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "assets/image-48x48-20260627151302.png",
    "96": "assets/image-96x96-20260627151304.png"
  }
}
